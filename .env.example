# ===========================================
# DTF Layout - Environment Configuration
# ===========================================

# Supabase Configuration (Required)
# Get these from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# Payment Gateway - Dodo Payments (Required)
# ===========================================
# Get these from: Dodo Payments Dashboard > API Keys
DODO_API_KEY=your-dodo-api-key
DODO_API_SECRET=your-dodo-api-secret
DODO_WEBHOOK_SECRET=your-webhook-secret

# Legacy Razorpay (India only - will be replaced by Dodo)
# RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# ===========================================
# Notes
# ===========================================
# - Authentication is handled by Supabase Auth (email/password)
# - Credits are stored in Supabase 'credits' table
# - User profiles stored in Supabase 'profiles' table
# - Free trial credits: 10,000 sq.inches (configured in CreditsContext.tsx)
