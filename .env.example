# Outseta Configuration
# Get your Outseta domain from your Outseta account settings
# Format: your-subdomain.outseta.com (without https://)
VITE_OUTSETA_DOMAIN=your-domain.outseta.com

# API credentials (optional - only needed for server-side operations)
VITE_OUTSETA_API_KEY=your-api-key-here
VITE_OUTSETA_API_SECRET=your-api-secret-here

# Plan UIDs (from Outseta dashboard > Billing > Plans)
# Free Trial Plan: rmk5109g
# Update AuthPage.tsx if you want to change the default signup plan

# IMPORTANT: Custom Property Setup Required
# In your Outseta dashboard, create an Account custom property:
# - Name: Credits Balance
# - System Name: credits_balance (must match exactly)
# - Type: Number
# - This property is automatically set to 700 for new signups
